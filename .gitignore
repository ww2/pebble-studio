# Dependencies / build output
node_modules/
dist/
release/
test-results/
*.log
.DS_Store

# Python bytecode cache (from the build scripts)
__pycache__/
*.pyc

# Local assistant / working notes — kept on disk, never published
.claude/
CLAUDE.md
docs/

# Large self-contained runtime bundles (~300 MB total). Shipped as release
# assets, not committed; reproducible from the build scripts under scripts/.
vendor/qemu-pebble-win/
vendor/pebble-py/
vendor/pebble-sdk/

# Firmware build staging + backups (big binaries; not committed)
vendor/factory-snapshots/

# macOS time-shim: the .c sources ARE committed; the compiled artifacts are
# generated at build time (see scripts/build-timeshim-mac.mjs) and must NOT be
# committed. Ad-hoc-signed Mach-O, host-arch specific.
vendor/timeshim-mac/timeshim.dylib
vendor/timeshim-mac/probe

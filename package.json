{
  "name": "pebble-studio",
  "version": "2.1.12",
  "description": "Modern GUI for the qemu-pebble emulator",
  "author": "Jason Lin",
  "main": "dist/main/index.cjs",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --outfile=dist/main/index.cjs && esbuild src/main/preload.cts --bundle --platform=node --format=cjs --target=node20 --external:electron --outfile=dist/main/preload.cjs && node -e \"require('fs').copyFileSync('src/main/splash.html','dist/main/splash.html')\"",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev": "vite",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win && node scripts/set-exe-icon.mjs",
    "gen:icon": "node scripts/gen-icon.mjs"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/pngjs": "^6.0.5",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^3.0.1",
    "resedit": "^3.0.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@novnc/novnc": "^1.5.0",
    "gif.js": "^0.2.0",
    "pngjs": "^7.0.0"
  }
}

{
  "name": "pebble-studio",
  "version": "0.0.1",
  "description": "Modern GUI for the qemu-pebble emulator",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev": "vite",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@novnc/novnc": "^1.5.0",
    "gif.js": "^0.2.0",
    "pngjs": "^7.0.0"
  }
}

diff --git a/hw/timer/stm32_pebble_tim.c b/hw/timer/stm32_pebble_tim.c
index ce6ddafcd1..3f42b61c97 100644
--- a/hw/timer/stm32_pebble_tim.c
+++ b/hw/timer/stm32_pebble_tim.c
@@ -31,6 +31,7 @@
 #include "qemu/timer.h"
 #include "qemu/log.h"
 #include "qapi/error.h"
+#include "migration/vmstate.h"
 
 //#define DEBUG_STM32F2XX_TIM
 #ifdef DEBUG_STM32F2XX_TIM
@@ -226,7 +227,10 @@ f2xx_tim_write(void *arg, hwaddr addr, uint64_t data, unsigned int size)
              && ((s->regs[R_TIM_CCMR1] & 0x60) == 0x60)
              && ((s->regs[R_TIM_CCMR1] & 0x03) == 0x00)) {
 
-            uint32_t ratio = (s->regs[R_TIM_CCR1] * 255) / s->regs[R_TIM_ARR];
+            /* Guard ARR==0: after migration/reset ARR may not be programmed
+             * yet; dividing by it crashed qemu (host SIGFPE) on restore. */
+            uint32_t ratio = s->regs[R_TIM_ARR] ?
+                (s->regs[R_TIM_CCR1] * 255) / s->regs[R_TIM_ARR] : 0;
             DPRINTF("Setting PWM ratio to %d\n", ratio);
             qemu_set_irq(s->pwm_ratio_changed, ratio);
         }
@@ -236,7 +240,9 @@ f2xx_tim_write(void *arg, hwaddr addr, uint64_t data, unsigned int size)
              && ((s->regs[R_TIM_CCMR1] & 0x6000) == 0x6000)
              && ((s->regs[R_TIM_CCMR1] & 0x0300) == 0x0000)) {
 
-            uint32_t ratio = (s->regs[R_TIM_CCR2] * 255) / s->regs[R_TIM_ARR];
+            /* Guard ARR==0 (see above). */
+            uint32_t ratio = s->regs[R_TIM_ARR] ?
+                (s->regs[R_TIM_CCR2] * 255) / s->regs[R_TIM_ARR] : 0;
             DPRINTF("Setting PWM ratio to %d\n", ratio);
             qemu_set_irq(s->pwm_ratio_changed, ratio);
 
@@ -301,11 +307,26 @@ f2xx_tim_realize(DeviceState *dev, Error **errp)
     qdev_init_gpio_out_named(dev, &s->pwm_enable, "pwm_enable", 1);
 }
 
+/* Migrate the register file and the tick timer so a restored guest sees the
+ * timer state it saved (previously nothing was migrated: regs came back as 0,
+ * and the firmware's first PWM CCER write divided by ARR==0 -> host SIGFPE). */
+static const VMStateDescription vmstate_f2xx_tim = {
+    .name = "f2xx_tim",
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .fields = (const VMStateField[]) {
+        VMSTATE_TIMER_PTR(timer, f2xx_tim),
+        VMSTATE_UINT32_ARRAY(regs, f2xx_tim, R_TIM_MAX),
+        VMSTATE_END_OF_LIST()
+    }
+};
+
 static void
 f2xx_tim_class_init(ObjectClass *klass, const void *data)
 {
     DeviceClass *dc = DEVICE_CLASS(klass);
     dc->realize = f2xx_tim_realize;
+    dc->vmsd = &vmstate_f2xx_tim;
     device_class_set_legacy_reset(dc, f2xx_tim_reset);
 }
 

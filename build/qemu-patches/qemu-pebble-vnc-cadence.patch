+/* Pebble Studio: nudge every backed-off display listener back to the default
+ * refresh cadence. Called when emulated input arrives out-of-band (serial
+ * button channel), mirroring what protocol_client_msg does for VNC client
+ * key/pointer events. Without this the VNC idle back-off can leave the first
+ * frame after a button press up to VNC_REFRESH_INTERVAL_MAX ms late. */
+void dpy_wake_refresh(void)
+{
+    DisplayState *s = display_state;
+    DisplayChangeListener *dcl;
+
+    if (!s) {
+        return;
+    }
+    QLIST_FOREACH(dcl, &s->listeners, next) {
+        if (dcl->update_interval > GUI_REFRESH_INTERVAL_DEFAULT) {
+            update_displaychangelistener(dcl, GUI_REFRESH_INTERVAL_DEFAULT);
+        }
+    }
+}
+
 void unregister_displaychangelistener(DisplayChangeListener *dcl)
 {
     DisplayState *ds = dcl->ds;

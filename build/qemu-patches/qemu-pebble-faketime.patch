+// ---------------------------------------------------------------------------
+// Pebble fake-time (native-Windows custom time / freeze / rate).
+//
+// On Linux the app fakes the qemu process's CLOCK_REALTIME with an LD_PRELOAD
+// shim (vendor/timeshim). Windows has no LD_PRELOAD, and an injected-DLL API
+// hook could not reach the host-clock path mingw's gettimeofday() actually uses,
+// so custom time silently reverted to real time after a few seconds. We instead
+// honor the SAME control-file contract HERE, inside the only place that matters:
+// the Pebble RTC's host-time reads. Every host-time read in THIS file must use
+// pebble_faketime_us() so the fake base/rate is internally consistent (the
+// host->target offset is computed against the same clock the RTC is jammed from
+// — mixing real + fake would make the offset cancel the fake out).
+//
+// Control file (PEBBLE_FAKETIME_FILE), one line: "<target_unix|-> <rate>"
+//   "1577836800 1" -> jump fake clock to 2020-01-01T00:00:00Z, run 1x
+//   "- 0"          -> keep current fake time, freeze
+//   "- 10"         -> keep current fake time, run 10x
+// Env fallbacks (read once): PEBBLE_FAKETIME_OFFSET (sec), PEBBLE_FAKETIME_RATE.
+// Re-read on mtime change, throttled to 200ms. Mirrors vendor/timeshim/timeshim.c.
+// All callers run under the BQL, so no locking is needed.
+// ---------------------------------------------------------------------------
+static int64_t      pebble_ft_anchor_real_us = 0;
+static int64_t      pebble_ft_anchor_fake_us = 0;
+static double       pebble_ft_rate = 1.0;
+static const char  *pebble_ft_ctl = NULL;
+static int          pebble_ft_ready = 0;
+static char         pebble_ft_last_line[64] = {0};   /* last control line applied */
+static int64_t      pebble_ft_last_check_us = 0;
+static int64_t      pebble_ft_last_log_us = 0;
+
+/* DIAG: append to PEBBLE_FAKETIME_LOG (if set) — confirms, from inside the REAL
+ * qemu process, whether PEBBLE_FAKETIME_FILE arrived, whether the ctl is read,
+ * and what fake time is served. Remove once custom time is confirmed working. */
+static void pebble_ft_log(const char *fmt, ...)
+{
+    const char *lp = getenv("PEBBLE_FAKETIME_LOG");
+    FILE *f;
+    va_list ap;
+
+    if (!lp || !lp[0]) {
+        return;
+    }
+    f = fopen(lp, "a");
+    if (!f) {
+        return;
+    }
+    va_start(ap, fmt);
+    vfprintf(f, fmt, ap);
+    va_end(ap);
+    fclose(f);
+}
+
+static int64_t pebble_real_us(void)
+{
+    struct timeval tv;
+    gettimeofday(&tv, NULL);
+    return tv.tv_sec * 1000000LL + tv.tv_usec;
+}
+
+static int64_t pebble_fake_locked(int64_t real_us)
+{
+    return pebble_ft_anchor_fake_us
+         + (int64_t)((double)(real_us - pebble_ft_anchor_real_us) * pebble_ft_rate);
+}
+
+static void pebble_ft_init(void)
+{
+    const char *o = getenv("PEBBLE_FAKETIME_OFFSET");
+    const char *r = getenv("PEBBLE_FAKETIME_RATE");
+    int64_t real = pebble_real_us();
+
+    pebble_ft_ctl = getenv("PEBBLE_FAKETIME_FILE");
+    pebble_ft_anchor_real_us = real;
+    pebble_ft_anchor_fake_us = real + (o ? (int64_t)atoll(o) * 1000000LL : 0);
+    pebble_ft_rate = r ? atof(r) : 1.0;
+    pebble_ft_ready = 1;
+    pebble_ft_log("[ft-init] FILE=%s OFFSET=%s RATE=%s anchor_fake_us=%lld\n",
+                  pebble_ft_ctl ? pebble_ft_ctl : "(null)", o ? o : "(null)",
+                  r ? r : "(null)", (long long)pebble_ft_anchor_fake_us);
+}
+
+static void pebble_ft_check_ctl(int64_t real_us)
+{
+    FILE *f;
+    char line[64];
+    char tgt[64];
+    double r;
+
+    if (!pebble_ft_ctl) {
+        return;
+    }
+    if (real_us - pebble_ft_last_check_us < 200000) {   /* 200ms throttle */
+        return;
+    }
+    pebble_ft_last_check_us = real_us;
+
+    /* Detect changes by the file's CONTENT, not stat() mtime: on Windows a
+     * cross-process stat() can return a stale last-write time for seconds (so
+     * the watch never picked up a custom time set after boot), but a fresh
+     * fopen()+read always returns the current bytes. We only re-anchor when the
+     * line actually changed — re-applying every poll would pin an absolute
+     * target in place (it could never advance at its rate). */
+    f = fopen(pebble_ft_ctl, "r");
+    if (!f) {
+        return;
+    }
+    if (!fgets(line, sizeof(line), f)) {
+        fclose(f);
+        return;
+    }
+    fclose(f);
+    if (strcmp(line, pebble_ft_last_line) == 0) {
+        return;                                           /* unchanged → leave as-is */
+    }
+    if (sscanf(line, "%63s %lf", tgt, &r) == 2) {
+        int64_t cur_fake = pebble_fake_locked(real_us);
+        /* commit the new line only after a successful parse, so a torn/partial
+         * write is retried on the next poll instead of being latched. */
+        strncpy(pebble_ft_last_line, line, sizeof(pebble_ft_last_line) - 1);
+        pebble_ft_last_line[sizeof(pebble_ft_last_line) - 1] = '\0';
+        pebble_ft_anchor_real_us = real_us;
+        if (tgt[0] == '-' && tgt[1] == '\0') {
+            pebble_ft_anchor_fake_us = cur_fake;          /* keep current fake */
+        } else {
+            pebble_ft_anchor_fake_us = (int64_t)atoll(tgt) * 1000000LL;
+        }
+        pebble_ft_rate = r;
+        pebble_ft_log("[ft-ctl] read tgt=%s rate=%.3f anchor_fake_us=%lld\n",
+                      tgt, r, (long long)pebble_ft_anchor_fake_us);
+    }
+}
+
+// Fake host wall-clock in microseconds (custom base + freeze/rate). Drop-in
+// replacement for the gettimeofday()-derived host_time_us the RTC used to read.
+// Non-static: also called by the generic Pebble RTC (hw/misc/pebble_rtc.c) so
+// the Cortex-M33 boards (emery/gabbro/flint) — whose modern qemu board "follows
+// the host RTC" and ignores SetUTC — honor the same custom-time/freeze/rate
+// control file. Both files link into the single qemu-system-arm binary.
+int64_t pebble_faketime_us(void)
+{
+    int64_t real;
+
+    if (!pebble_ft_ready) {
+        pebble_ft_init();
+    }
+    real = pebble_real_us();
+    pebble_ft_check_ctl(real);
+    if (real - pebble_ft_last_log_us > 1000000) {   /* ~1s throttle */
+        pebble_ft_last_log_us = real;
+        pebble_ft_log("[ft-now] fake_unix=%lld rate=%.3f\n",
+                      (long long)(pebble_fake_locked(real) / 1000000LL), pebble_ft_rate);
+    }
+    return pebble_fake_locked(real);
+}

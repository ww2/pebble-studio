-    // Get the host time in microseconds
-    struct timeval tv;
-    gettimeofday(&tv, NULL);
-    int64_t host_time_us = tv.tv_sec * 1000000LL + (tv.tv_usec);
+    // Get the host time in microseconds (faked: custom base + freeze/rate).
+    int64_t host_time_us = pebble_faketime_us();
 

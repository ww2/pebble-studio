+// Pebble emulator: reserved RTC offset that reads the REAL (unfrozen) host wall
+// clock in MICROSECONDS, low 32 bits (wraps ~71 min; only sub-second deltas are
+// taken). The guest firmware reads this ONLY in its frozen-clock STOP-elapsed
+// fallback (drivers/stm32f4/rtc.c) so the scheduler can measure true elapsed time
+// (to sub-tick precision) even while the displayed RTC is frozen for custom time.
+// Reserved on real STM32F4 (0x40002A00) and never read there.
+#define R_RTC_PEBBLE_REALUS (0x200 / 4)
+

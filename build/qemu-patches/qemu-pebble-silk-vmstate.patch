+static int sm_lcd_post_load(void *opaque, int version_id)
+{
+    SmLcdState *s = opaque;
+
+    /* The QemuConsole surface has no vmstate, so the restored framebuffer must
+     * be repainted immediately: sm_lcd_update_display() only draws when redraw
+     * is set and reads s->framebuffer directly. Without this the memory LCD

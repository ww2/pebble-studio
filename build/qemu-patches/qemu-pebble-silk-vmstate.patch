+        VMSTATE_BOOL(backlight_enabled, SmLcdState),
+        VMSTATE_BOOL(vibrate_on, SmLcdState),
+        VMSTATE_INT32(vibrate_offset, SmLcdState),
+        VMSTATE_BOOL(power_on, SmLcdState),
+        VMSTATE_END_OF_LIST()
+    }

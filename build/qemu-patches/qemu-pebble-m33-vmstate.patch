+        VMSTATE_UINT32(alarm, PblRtc),
+        VMSTATE_UINT32(ctrl, PblRtc),
+        VMSTATE_UINT32_ARRAY(backup, PblRtc, RTC_NUM_BACKUP),
+        VMSTATE_END_OF_LIST()
+    }
+};

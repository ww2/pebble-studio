 #include "qemu/osdep.h"
+#include "migration/vmstate.h"
 #include "qemu/log.h"
 #include "qemu/timer.h"
 #include "hw/irq.h"
@@ -510,10 +511,42 @@ static const Property pbl_display_properties[] = {
     DEFINE_PROP_BOOL("round-mask", PblDisplay, round_mask, false),
 };
 
+static int pbl_display_post_load(void *opaque, int version_id)
+{
+    PblDisplay *s = opaque;
+
+    /* The QemuConsole surface has no vmstate: repaint the restored
+     * framebuffer immediately (render reads s->fb directly). */
+    s->redraw = true;
+    return 0;
+}
+
+static const VMStateDescription vmstate_pbl_display = {
+    .name = "pebble-display",
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .post_load = pbl_display_post_load,
+    .fields = (const VMStateField[]) {
+        VMSTATE_VBUFFER_UINT32(fb, PblDisplay, 0, NULL, fb_size),
+        VMSTATE_UINT32(ctrl, PblDisplay),
+        VMSTATE_UINT32(brightness, PblDisplay),
+        VMSTATE_UINT32(intstat, PblDisplay),
+        VMSTATE_UINT32(intctrl, PblDisplay),
+        VMSTATE_UINT8(bl_r, PblDisplay),
+        VMSTATE_UINT8(bl_g, PblDisplay),
+        VMSTATE_UINT8(bl_b, PblDisplay),
+        VMSTATE_BOOL(vibrating, PblDisplay),
+        VMSTATE_INT32(vibe_frame, PblDisplay),
+        VMSTATE_TIMER_PTR(vibe_timer, PblDisplay),
+        VMSTATE_END_OF_LIST()
+    }
+};
+
 static void pbl_display_class_init(ObjectClass *klass, const void *data)
 {
     DeviceClass *dc = DEVICE_CLASS(klass);
 
+    dc->vmsd = &vmstate_pbl_display;
     dc->realize = pbl_display_realize;
     device_class_set_legacy_reset(dc, pbl_display_reset);
     device_class_set_props(dc, pbl_display_properties);

 #include "qemu/timer.h"
 #include "hw/irq.h"
@@ -61,10 +62,22 @@ static void pbl_rtc_update_irq(PblRtc *s)
                           (s->ctrl & CTRL_ALARM_IRQ));
 }
 
-/* Return the host wall-clock time, in seconds, as a UTC unix timestamp. */
+/* Pebble fake-time host clock (custom base + freeze/rate), defined in
+ * hw/timer/stm32_pebble_rtc.c and shared across the single qemu-system-arm
+ * binary. Returns the (possibly faked) host wall-clock in microseconds, driven
+ * by the PEBBLE_FAKETIME_FILE control file. On the Cortex-M4 boards the f2xx
+ * RTC re-jams the guest clock from this; here it is the generic RTC's host
+ * source. The modern pebble-emery/gabbro/flint board "follows the host RTC" and
+ * ignores SetUTC, so faking this function is the ONLY lever for custom time,
+ * freeze, and accelerated rates on those Cortex-M33 boards. */
+extern int64_t pebble_faketime_us(void);
+
+/* Return the host wall-clock time, in seconds, as a UTC unix timestamp.
+ * Uses the shared Pebble fake clock so custom time / freeze / rate work here
+ * exactly as on the f2xx boards (real hardware always advances → unaffected). */
 static int64_t pbl_rtc_host_time(void)
 {
-    return qemu_clock_get_ms(QEMU_CLOCK_HOST) / 1000;
+    return pebble_faketime_us() / 1000000LL;
 }
 
 /* Return the RTC's current time: host wall-clock plus the guest-set offset.
@@ -188,9 +201,23 @@ static void pbl_rtc_reset(DeviceState *dev)
     /* Backup registers intentionally NOT cleared on reset */
 }
 
